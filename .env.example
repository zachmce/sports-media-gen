# .env.example — copy to .env for local development; never commit .env
POSTGRES_USER=matchup
POSTGRES_PASSWORD=changeme
POSTGRES_DB=matchup
POSTGRES_DSN=postgresql+psycopg://matchup:changeme@localhost:5432/matchup
REDIS_URL=redis://localhost:6379/0
LOG_LEVEL=INFO
RENDER_VERSION=1

# Host ports (published to host via docker compose; change to avoid collisions)
NGINX_HOST_PORT=8080   # Host port for nginx front door (default: 8080; avoids 8000 used by api)

# nginx trusted-proxy CIDR — CIDR range of your upstream load-balancer or CDN.
# nginx trusts X-Forwarded-For headers only from IPs within this range.
# Default 172.16.0.0/12 covers docker-compose default bridge ranges (172.17–172.31).
# WARNING: setting 0.0.0.0/0 allows any client to spoof X-Forwarded-For and bypass per-IP rate limits.
NGINX_TRUSTED_PROXY_CIDR=172.16.0.0/12
