# .env.example — copy to .env for local development; never commit .env
POSTGRES_USER=matchup
POSTGRES_PASSWORD=changeme
POSTGRES_DB=matchup
POSTGRES_DSN=postgresql+psycopg://matchup:changeme@localhost:5432/matchup
REDIS_URL=redis://localhost:6379/0
LOG_LEVEL=INFO
RENDER_VERSION=1

# Host ports (published to host via docker compose; change to avoid collisions)
NGINX_HOST_PORT=8080   # Host port for nginx front door (default: 8080; avoids 8000 used by api)
