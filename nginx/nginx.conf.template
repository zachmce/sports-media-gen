# nginx/nginx.conf.template — envsubst template; rendered to /etc/nginx/nginx.conf
# by the nginx image's stock 20-envsubst-on-templates.sh entrypoint.
# Intentionally does NOT include conf.d/*.conf so the image's default static-file
# server (conf.d/default.conf) cannot shadow this proxy (RESEARCH Pitfall 1).
#
# ─────────────────────────────────────────────────────────────────────────────
# Named constants (no magic numbers — CLAUDE.md discipline)
# ─────────────────────────────────────────────────────────────────────────────
# CACHE_ZONE_SIZE   10m    -- ~80k cache keys in shared memory (keys_zone)
# CACHE_MAX_SIZE     1g    -- disk cap for proxy_cache files on nginxcache volume
# CACHE_TTL         30d    -- mirrors app Cache-Control: max-age=2592000, immutable
# CACHE_INACTIVE    30d    -- evict entries not accessed within 30 days
# LOCK_TIMEOUT       5s    -- bound collapse wait: concurrent MISSes → 1 upstream call
# RATE_LIMIT       10r/s   -- 10 image requests per second per resolved client IP
# RATE_BURST          20   -- absorb short bursts; nodelay = no queuing delay
# RATE_ZONE_SIZE    10m    -- ~160k client state entries (binary_remote_addr)

user  nginx;
worker_processes  auto;

error_log  /var/log/nginx/error.log notice;
pid        /run/nginx.pid;

events {
    worker_connections  1024;
}

http {
    include       /etc/nginx/mime.types;
    default_type  application/octet-stream;

    # ── Real-IP: resolve true client IP from X-Forwarded-For ─────────────────
    # NGINX_TRUSTED_PROXY_CIDR (default 172.16.0.0/12): upstream LB/CDN CIDR.
    # 172.16.0.0/12 covers all docker-compose default bridge ranges (172.17–172.31).
    # 127.0.0.1 covers localhost / direct dev access — always trusted, never varies.
    # real_ip_recursive on: walks X-Forwarded-For right-to-left and sets
    #   $remote_addr to the first *non-trusted* hop — required so rate-limit
    #   keys on the true client IP, not the compose gateway (RESEARCH Pitfall 6).
    set_real_ip_from  ${NGINX_TRUSTED_PROXY_CIDR};
    set_real_ip_from  127.0.0.1;
    real_ip_header    X-Forwarded-For;
    real_ip_recursive on;

    # ── Rate-limit zone: keyed on true client IP (resolved via realip above) ─
    # limit_req_status 429 is explicit; nginx default is 503 (RESEARCH Pitfall 3).
    limit_req_zone $binary_remote_addr zone=gen_limit:10m rate=10r/s;
    limit_req_status 429;

    # ── Proxy cache zone ──────────────────────────────────────────────────────
    # use_temp_path=off: writes cache files directly to the cache dir, avoiding
    # cross-filesystem moves (nginx 1.7.10+, available in stable-alpine3.23).
    proxy_cache_path /var/cache/nginx/matchup
        levels=1:2
        keys_zone=matchup_cache:10m
        max_size=1g
        inactive=30d
        use_temp_path=off;

    # ── Upstream ──────────────────────────────────────────────────────────────
    # api:8000 resolves via docker-compose network DNS at runtime.
    # keepalive 32 reuses connections for high-frequency image requests.
    upstream api {
        server api:8000;
        keepalive 32;
    }

    # ── Logging: include cache status in every access-log line ───────────────
    log_format  main  '$remote_addr - $remote_user [$time_local] "$request" '
                      '$status $body_bytes_sent "$http_referer" '
                      '"$http_user_agent" "$http_x_forwarded_for" '
                      'cache=$upstream_cache_status';

    access_log  /var/log/nginx/access.log  main;
    sendfile    on;
    keepalive_timeout  65;

    server {
        listen 80;
        server_name _;

        # ── Default proxy headers (inherited by all locations) ────────────────
        proxy_set_header  Host              $host;
        proxy_set_header  X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header  X-Forwarded-Proto $scheme;
        proxy_set_header  X-Request-ID      $request_id;

        # ── Cache observability on all responses ──────────────────────────────
        # Placed at server{} level ONLY. Do NOT add add_header inside any
        # location{} block — nginx drops parent add_header directives when a
        # child block also contains add_header (RESEARCH §"add_header Inheritance
        # Critical Note", D-14).
        add_header X-Cache-Status $upstream_cache_status always;

        # ── Exact-match exempt: probes + listings ─────────────────────────────
        # Exact matches are checked before any regex (nginx eval order, step 1).
        # These endpoints must always reach the app; never rate-limited/cached.
        location = /healthz  { proxy_pass http://api; }
        location = /readyz   { proxy_pass http://api; }
        location = /metrics  { proxy_pass http://api; }
        location = /leagues  { proxy_pass http://api; }

        # ── Teams listing: straight proxy, no rate-limit, no cache ───────────
        # Placed before the image regex (defensive clarity convention; the two
        # patterns are mutually exclusive — /nba/teams has no kind segment, so
        # the image regex below cannot match it regardless of order).
        location ~ ^/[^/]+/teams$ {
            proxy_pass http://api;
        }

        # ── Image generation routes: cached + rate-limited ───────────────────
        # Matches: /{league}/{away}/{home}/{kind}   (4-segment, e.g. /nba/..., /ncaaf/...)
        # kind ∈ {thumb, logo, poster} — mirrors the generator registry.
        # NOTE: if a new kind is added to the generator registry, add it here.
        location ~ ^/[^/]+/.+/(thumb|logo|poster)$ {
            # Cache zone + key (D-04, D-05, D-06, D-07)
            proxy_cache         matchup_cache;
            proxy_cache_key     "$scheme$request_method$host$request_uri";
            proxy_cache_valid   200 30d;       # ONLY 200 cached; 404/5xx never stored (SC-3)
            proxy_cache_methods GET HEAD;
            proxy_cache_lock    on;            # Collapse concurrent MISSes for same key (D-07)
            proxy_cache_lock_timeout 5s;       # nginx-tier complement to app's Redis SET NX

            # Rate-limit (D-10): burst=20 absorbs brief spikes; nodelay returns
            # 429 immediately on burst overflow (no queuing delay).
            limit_req zone=gen_limit burst=20 nodelay;

            proxy_pass http://api;
        }

        # ── Default: pass everything else through ─────────────────────────────
        location / {
            proxy_pass http://api;
        }
    }
}
